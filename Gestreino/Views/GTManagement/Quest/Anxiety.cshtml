@model Gestreino.Models.GT_Quest_Anxient
@using System;
@using System.Globalization;
@using Gestreino.Classes
@{
    ViewBag.Title = "Ansiedade e Depressão";
}
@if (!string.IsNullOrEmpty(Cookies.ReadCookie(Cookies.COOKIES_GESTREINO_AVALIADO)) && Session["GESTREINO_AVALIDO_NOME"] != null)
{
    <style>
        .animated ul {
            list-style: none;
            padding: 0 17px !important;
        }

        .animated label {
            margin-bottom: 5px !important
        }
        .table td, .table th:not(#GTQuestTable) {
            border-top: none !important;
            padding: .25rem .75rem !important;
        }
    </style>
    <!-- page content -->
    <div class="right_col" role="main">
        <div class="row">
            <div class="col-md-12 col-sm-12 ">
                @using (Ajax.BeginForm("anxiety", "gtmanagement", new AjaxOptions { HttpMethod = "POST", OnFailure = "handleFailure", OnSuccess = "handleSuccess", UpdateTargetId = "" }, new { Id = "anxientForm" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.PEsId)
                    @Html.HiddenFor(m => m.ID)
                    <input type="hidden" value="2" name="frmaction" />
                    <input type="hidden" value="GT_RespAnsiedadeDepressao" id="GT_Res" />
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <div class="btn-group" style="border:1px solid #ddd; border-radius:4px">
                                @if (AcessControl.Authorized(AcessControl.GT_QUEST_ANXIETY_UPDATE))
                                {<a title="Novo" href="@Url.Action("anxiety", "gtmanagement",new { Id = string.Empty })" class="btn btn-light"><img src="~/Assets/images/new.png" width="26" /> Novo</a>
                                }
                                <a href="javascript:" data-placement="top" title="" class="open-modal-crud btn btn-light" data-id="0" data-action="anxiety" data-entity="gtquest" data-toggle="modal" data-target="#crudControlModal">
                                    <img src="~/Assets/images/search.png" width="19" />  Ver resultado
                                </a>
                                <button type="button" disabled class="btn btn-light" title="Imprimir"><img src="~/Assets/images/printer.png" width="19" /> Imprimir</button>
                                <button type="button" class="btn btn-light" onclick="openHelpWindow('Avaliacoes')" title="Ajuda"><img src="~/Assets/images/help.png" width="19" /> Ajuda</button>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-9">
                            <div class="animated flipInY">
