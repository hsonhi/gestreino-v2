                                    <div class="tile-stats-header">
                                        <div class="icon">
                                            <i class="fa fa-clipboard-check"></i>
                                        </div>
                                        <h3 class="p-2">Ansiedade e Depressão</h3>
                                    </div>
                                    @if (Model.ID > 0)
                                    {
                                        CultureInfo frenchCulture = new CultureInfo("pt-PT");
                                        <div class="p-2" style="padding-bottom:0 !important">
                                            <div class="p-2" style="padding-bottom:0 !important">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="alert alert-soft-success"
                                                             role="alert" style="margin-bottom:0!important">
                                                            <div class="d-flex flex-wrap align-items-start">
                                                                <div class="mr-8pt">
                                                                    <i class="fa fa-briefcase-clock mr-12pt"></i> <strong>@Session["GESTREINO_AVALIDO_NOME"]:</strong>
                                                                </div>
                                                                <div class="flex"
                                                                     style="min-width: 180px">
                                                                    <span class="text-black-100">
                                                                        &nbsp;@ViewBag.data[0].DATA_INSERCAO.ToString("dd MMMM yyyy HH:mm", frenchCulture)
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
