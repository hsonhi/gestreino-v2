@using Gestreino.Models
@model PasswordResetViewModel
@{
    ViewBag.Title = "Recuperar senha de acesso";
}
<div class="login_wrapper">
    <div class="animate form login_form">
        <section class="login_content">
            @using (Ajax.BeginForm("../Account/PasswordRecovery", null, new AjaxOptions { HttpMethod = "POST", LoadingElementId = "", LoadingElementDuration = 2000, OnBegin = "loadIn", OnComplete = "loadOut", OnSuccess = "handleSuccess", OnFailure = "handleFailure", UpdateTargetId = "" }, new { id = "" }))
            {
                @Html.AntiForgeryToken()
                <h1><img src="~/Assets/images/logo.png" width="160" class="navImg" /></h1>
                <h2>Recuperar senha de acesso</h2>
                <div class="row">
                    <div class="col-lg-12">
                        <div class="handle-error alert alert-accent mb-2"
                             role="alert" style="display: none;">
                            <div class="d-flex flex-wrap align-items-start">
                                <div class="mr-8pt">
                                    <i class="fa-solid fa-shield-halved mr-12pt"></i> <strong>Atenção!</strong>
                                </div>
                                <div class="flex"
                                     style="min-width: 180px">
                                    <span class="text-black-100">
                                        &nbsp;<span class="handle-error-message"></span>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="handle-success alert alert-soft-success"
                             role="alert" style="display:none;">
                            <div class="d-flex flex-wrap align-items-start">
                                <div class="mr-8pt">
                                    <i class="fa fa-check-circle mr-12pt"></i> <strong>Successo!</strong>
                                </div>
                                <div class="flex"
                                     style="min-width: 180px">
                                    <span class="text-black-100">
                                        &nbsp;<span class="handle-success-message"></span>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        @Html.ValidationSummary(true, "", new { @class = "ValidationSummary text-danger" })
                    </div>
                </div>
                <div class="row">
                    @Html.LabelFor(m => m.Email, new { @class = "col-md-2 col-form-label" })
                    <div class="col-md-10">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", required = "", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="row">
                    <label class="col-md-2 col-form-label"></label>
                    <div class="col-md-10">
                        <input type="submit" class="btn btn-secondary submit" value="Enviar link">
                    </div>
                </div>
                <div class="row mb-4 mt-3">
                    <label class="col-md-2 col-form-label"></label>
                    <div class="col-md-10">
                        @Html.ActionLink("Iniciar sessão", "login", new { }, new { @class = "" })
                    </div>
            </div>
        }
        </section>
    </div>
</div>